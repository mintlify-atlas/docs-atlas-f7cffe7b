  "keyFeatures": [
    "Dual-role user system (Seekers and Providers)",
    "OTP-based phone number authentication",
    "Job posting with category, urgency, and image upload",
    "Competitive bidding system for service providers",
    "Bid acceptance and job lifecycle management (pending, active, completed, canceled)",
    "Provider and seeker dashboards with filtered job views",
    "22+ service categories including plumbing, electrical, cleaning, landscaping, and more",
    "JWT cookie-based session management",
    "Profile management with picture upload",
    "Payment gateway integration (Razorpay, partially implemented)"
  ],
